{
  "name": "newscut",
  "productName": "NEWSCUT",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "setup:py": "python -m venv .venv && .venv/Scripts/python -m pip install google-genai python-dotenv requests openai moviepy gtts",
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --external:vite --outfile=dist/server.cjs",
    "build:py": ".venv\\Scripts\\pyinstaller --noconfirm --clean --onedir --name pipeline --collect-all imageio_ffmpeg --copy-metadata imageio --copy-metadata imageio_ffmpeg --hidden-import video_composer --distpath dist-py pipeline.py",
    "dist:win": "npm run build && npm run build:py && electron-builder --win",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist dist-py release server.js",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.newscut.app",
    "productName": "NEWSCUT",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-py/pipeline",
        "to": "pipeline"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "NEWSCUT"
    }
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
